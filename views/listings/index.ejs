<% layout("/layouts/boilerplate") %>

<style>
  .filter-bar-container {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 4px 16px;
    flex-wrap: wrap;
    position: relative;
    z-index: 100;
  }
  
  .filter-group {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  
  .filter-group-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-main);
    text-transform: uppercase;
    white-space: nowrap;
    opacity: 0.7;
  }
  
  .filter-chips-container {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  
  .filter-chip {
    padding: 6px 14px;
    background: white;
    border: 1px solid #ddd;
    border-radius: 20px;
    cursor: pointer;
    font-size: 0.9rem;
    transition: all 0.2s ease;
    white-space: nowrap;
    text-decoration: none;
    color: var(--text-main);
  }
  
  .filter-chip:hover {
    border-color: var(--accent-primary);
  }
  
  .filter-chip.active {
    background: var(--accent-primary);
    color: white;
    border-color: var(--accent-primary);
    font-weight: 600;
  }
  
  .dropdown {
    position: relative;
    z-index: 1050;
  }
  
  .dropdown:hover .dropdown-menu {
    display: block !important;
  }
  
  .dropdown-menu {
    min-width: 220px;
    position: absolute;
    z-index: 1051;
  }
  
  .dropdown-item.active {
    background-color: var(--accent-primary) !important;
    color: white !important;
    font-weight: 600;
  }
  
  .dropdown-divider {
    margin: 4px 0;
  }
</style>

<div class="listings-wrapper">
  <!-- Top Filter & Search Bar -->
  <section class="filter-section border-bottom" style="background-color: var(--bg-primary); position: relative; z-index: 100;">
    <div class="filter-bar-container">
      
      <!-- Search Form -->
      <form class="search-form-filter d-flex align-items-center bg-white shadow-sm rounded-pill px-3 py-2" action="/listings" method="GET" style="border: 1px solid var(--accent-primary); width: 100%; max-width: 350px;">
        <i class="fa-solid fa-magnifying-glass" style="color: var(--accent-primary);"></i>
        <input type="text" name="q" placeholder="Search PG..." value="<%= typeof searchTerm !== 'undefined' ? searchTerm : '' %>" class="form-control border-0 bg-transparent ms-2" style="outline: none;">
        <% if(typeof selectedFilters !== 'undefined' && selectedFilters.length > 0) { %>
          <input type="hidden" name="filters" value="<%= selectedFilters.join(',') %>">
        <% } %>
        <% if(typeof sortBy !== 'undefined' && sortBy) { %>
          <input type="hidden" name="sort" value="<%= sortBy %>">
        <% } %>
        <button type="submit" class="btn btn-sm rounded-pill ms-2 text-white" style="background: var(--accent-primary); padding: 4px 14px; border: none;">Search</button>
      </form>

      <!-- Sort Dropdown -->
      <div class="dropdown">
        <button class="btn btn-sm btn-outline-secondary rounded-pill" type="button" data-bs-toggle="dropdown" style="white-space: nowrap;">
          <i class="fa-solid fa-arrow-down-wide-short me-1"></i> Sort
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
          <li><a class="dropdown-item <%= typeof sortBy !== 'undefined' && sortBy === 'price_asc' ? 'active' : '' %>" href="/listings?q=<%= typeof searchTerm !== 'undefined' ? encodeURIComponent(searchTerm) : '' %><%= (typeof selectedFilters !== 'undefined' && selectedFilters.length > 0) ? '&filters=' + selectedFilters.join(',') : '' %>&sort=price_asc">Price: Low to High</a></li>
          <li><a class="dropdown-item <%= typeof sortBy !== 'undefined' && sortBy === 'price_desc' ? 'active' : '' %>" href="/listings?q=<%= typeof searchTerm !== 'undefined' ? encodeURIComponent(searchTerm) : '' %><%= (typeof selectedFilters !== 'undefined' && selectedFilters.length > 0) ? '&filters=' + selectedFilters.join(',') : '' %>&sort=price_desc">Price: High to Low</a></li>
          <li><a class="dropdown-item <%= typeof sortBy !== 'undefined' && sortBy === 'highest_rated' ? 'active' : '' %>" href="/listings?q=<%= typeof searchTerm !== 'undefined' ? encodeURIComponent(searchTerm) : '' %><%= (typeof selectedFilters !== 'undefined' && selectedFilters.length > 0) ? '&filters=' + selectedFilters.join(',') : '' %>&sort=highest_rated">Highest Rated</a></li>
          <% if(typeof sortBy !== 'undefined' && sortBy) { %>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="/listings<%= (typeof searchTerm !== 'undefined' && searchTerm) ? '?q=' + encodeURIComponent(searchTerm) : '' %><%= (typeof selectedFilters !== 'undefined' && selectedFilters.length > 0) ? (typeof searchTerm !== 'undefined' && searchTerm ? '&' : '?') + 'filters=' + selectedFilters.join(',') : '' %>">Clear Sort</a></li>
          <% } %>
        </ul>
      </div>

      <!-- Budget Filter Group -->
      <div class="filter-group">
        <span class="filter-group-label">💰 Budget</span>
        <div class="filter-chips-container">
          <a class="filter-chip <%= (typeof selectedFilters !== 'undefined' && selectedFilters.includes('low-budget')) ? 'active' : '' %>" 
             href="/listings?q=<%= typeof searchTerm !== 'undefined' ? encodeURIComponent(searchTerm) : '' %>&filters=<%= selectedFilters.includes('low-budget') ? selectedFilters.filter(f => f !== 'low-budget').join(',') : [...(typeof selectedFilters !== 'undefined' ? selectedFilters : []), 'low-budget'].join(',') %><%= (typeof sortBy !== 'undefined' && sortBy) ? '&sort=' + sortBy : '' %>">
            Under ₹8K/mo
          </a>
          <a class="filter-chip <%= (typeof selectedFilters !== 'undefined' && selectedFilters.includes('mid-range')) ? 'active' : '' %>" 
             href="/listings?q=<%= typeof searchTerm !== 'undefined' ? encodeURIComponent(searchTerm) : '' %>&filters=<%= selectedFilters.includes('mid-range') ? selectedFilters.filter(f => f !== 'mid-range').join(',') : [...(typeof selectedFilters !== 'undefined' ? selectedFilters : []), 'mid-range'].join(',') %><%= (typeof sortBy !== 'undefined' && sortBy) ? '&sort=' + sortBy : '' %>">
            ₹8K-₹15K/mo
          </a>
          <a class="filter-chip <%= (typeof selectedFilters !== 'undefined' && selectedFilters.includes('premium-pg')) ? 'active' : '' %>" 
             href="/listings?q=<%= typeof searchTerm !== 'undefined' ? encodeURIComponent(searchTerm) : '' %>&filters=<%= selectedFilters.includes('premium-pg') ? selectedFilters.filter(f => f !== 'premium-pg').join(',') : [...(typeof selectedFilters !== 'undefined' ? selectedFilters : []), 'premium-pg'].join(',') %><%= (typeof sortBy !== 'undefined' && sortBy) ? '&sort=' + sortBy : '' %>">
            Above ₹15K/mo
          </a>
        </div>
      </div>

      <!-- Gender Preference Filter Group -->
      <div class="filter-group">
        <span class="filter-group-label">👥 Style</span>
        <div class="filter-chips-container">
          <a class="filter-chip <%= (typeof selectedFilters !== 'undefined' && selectedFilters.includes('boys-pg')) ? 'active' : '' %>" 
             href="/listings?q=<%= typeof searchTerm !== 'undefined' ? encodeURIComponent(searchTerm) : '' %>&filters=<%= selectedFilters.includes('boys-pg') ? selectedFilters.filter(f => f !== 'boys-pg').join(',') : [...(typeof selectedFilters !== 'undefined' ? selectedFilters : []), 'boys-pg'].join(',') %><%= (typeof sortBy !== 'undefined' && sortBy) ? '&sort=' + sortBy : '' %>">
            👨 Men
          </a>
          <a class="filter-chip <%= (typeof selectedFilters !== 'undefined' && selectedFilters.includes('girls-pg')) ? 'active' : '' %>" 
             href="/listings?q=<%= typeof searchTerm !== 'undefined' ? encodeURIComponent(searchTerm) : '' %>&filters=<%= selectedFilters.includes('girls-pg') ? selectedFilters.filter(f => f !== 'girls-pg').join(',') : [...(typeof selectedFilters !== 'undefined' ? selectedFilters : []), 'girls-pg'].join(',') %><%= (typeof sortBy !== 'undefined' && sortBy) ? '&sort=' + sortBy : '' %>">
            👩 Women
          </a>
          <a class="filter-chip <%= (typeof selectedFilters !== 'undefined' && selectedFilters.includes('co-living')) ? 'active' : '' %>" 
             href="/listings?q=<%= typeof searchTerm !== 'undefined' ? encodeURIComponent(searchTerm) : '' %>&filters=<%= selectedFilters.includes('co-living') ? selectedFilters.filter(f => f !== 'co-living').join(',') : [...(typeof selectedFilters !== 'undefined' ? selectedFilters : []), 'co-living'].join(',') %><%= (typeof sortBy !== 'undefined' && sortBy) ? '&sort=' + sortBy : '' %>">
            🏘️ Co-living
          </a>
        </div>
      </div>

      <!-- Top Rated Filter -->
      <div class="filter-group">
        <a class="filter-chip <%= (typeof selectedFilters !== 'undefined' && selectedFilters.includes('top-rated')) ? 'active' : '' %>" 
           href="/listings?q=<%= typeof searchTerm !== 'undefined' ? encodeURIComponent(searchTerm) : '' %>&filters=<%= selectedFilters.includes('top-rated') ? selectedFilters.filter(f => f !== 'top-rated').join(',') : [...(typeof selectedFilters !== 'undefined' ? selectedFilters : []), 'top-rated'].join(',') %><%= (typeof sortBy !== 'undefined' && sortBy) ? '&sort=' + sortBy : '' %>">
          ⭐ Top-Rated
        </a>
      </div>

      <!-- Clear Filters Button -->
      <% if(typeof selectedFilters !== 'undefined' && selectedFilters.length > 0) { %>
        <a href="/listings<%= (typeof searchTerm !== 'undefined' && searchTerm) ? '?q=' + encodeURIComponent(searchTerm) : '' %>" class="btn btn-sm btn-outline-danger rounded-pill">
          <i class="fa-solid fa-times me-1"></i> Clear
        </a>
      <% } %>
    </div>
  </section>

  <main class="listings-main-container" style="padding: 0.75rem 1rem;">
    <% if (!allListings || allListings.length === 0) { %>
      <div class="empty-state text-center py-5">
        <div class="empty-icon mb-3"><i class="fa-solid fa-house-chimney-crack fa-3x text-muted"></i></div>
        <h4 class="mb-2">No PGs Found</h4>
        <p class="text-muted mb-4">Try adjusting your filters or search terms.</p>
        <a href="/listings" class="btn btn-outline-dark rounded-pill px-4">Clear All Filters</a>
      </div>
    <% } else { %>
      <div class="pg-grid">
        <% allListings.forEach((listing, i) => { %>
          <a href="/listings/<%= listing._id %>" class="pg-card" style="animation-delay: <%= (i % 10) * 0.05 %>s">
            <div class="pg-image-wrap">
              <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="pg-image" loading="lazy">
              <div class="pg-reality-score">
                <span class="score-badge-small"><%= (typeof listing.realityScore === 'number' && listing.realityScore > 0) ? Math.round(listing.realityScore * 20) : "NR" %></span>
                <span class="score-label-small">Reality Score</span>
              </div>
            </div>

            <div class="pg-card-body">
              <div class="pg-header">
                <h3 class="pg-title"><%= listing.title %></h3>
                <div class="pg-location"><i class="fa-solid fa-location-dot text-muted"></i> <%= listing.location || "Location unverified" %></div>
              </div>

              <div class="pg-badges">
                <span class="pg-badge"><%= (listing.roomType || "-").replace(/^./, c => c.toUpperCase()) %></span>
                <span class="pg-badge"><%= listing.genderPreference ? listing.genderPreference.charAt(0).toUpperCase() + listing.genderPreference.slice(1) : "Any" %></span>
                <% if(listing.wifiAvailable) { %><span class="pg-badge icon-badge" title="High-Speed WiFi"><i class="fa-solid fa-wifi"></i></span><% } %>
                <% if(listing.foodIncluded) { %><span class="pg-badge icon-badge" title="Food Included"><i class="fa-solid fa-utensils"></i></span><% } %>
              </div>

              <div class="pg-finance">
                <div class="finance-line">
                  <span class="text-muted">Base Rent</span>
                  <span class="fw-medium text-dark">&#8377; <%= (listing.price || 0).toLocaleString("en-IN") %></span>
                </div>
                <div class="finance-line total-highlight">
                  <span class="fw-bold text-dark">True Monthly Cost</span>
                  <span class="finance-accent fw-bold">&#8377; <%= (listing.trueMonthlyCost || listing.price || 0).toLocaleString("en-IN") %></span>
                </div>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </main>
</div>
