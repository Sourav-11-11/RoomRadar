<% layout("/layouts/boilerplate") %>
<script>
  window.mapToken = "<%= process.env.MAPBOX_TOKEN %>";
</script>
<script id="listing-map-data" type="application/json"><%- JSON.stringify({
  title: listing.title,
  location: listing.location,
  country: listing.country,
  geometry: listing.geometry
}) %></script>
<div class="show-page">
<div class="row mt-3 justify-content-center">
  <div class="col-12 col-lg-8 px-2 px-lg-0">
    <h3 class="mb-4 d-flex align-items-center justify-content-between">
      <span><%= listing.title %></span>
      <span class="badge bg-dark">Reality Score: <%= listing.realityScore ? listing.realityScore.toFixed(1) : "--" %>/5</span>
    </h3>
    <div class="card listing-card mb-4">
      <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing image" >
      <div class="card-body p-4">
        <p class="card-text mb-3"><strong>Hosted by:</strong> <%= listing.owner ? listing.owner.username : 'Unknown Host' %></p>
        <p class="card-text mb-3"><strong>Description:</strong> <%= listing.description %></p>
        <p class="card-text mb-4"><i class="fa-solid fa-location-dot text-danger me-2"></i><%= listing.location %><% if (listing.country) { %>, <%= listing.country %><% } %></p>

        <div class="row g-3">
          <div class="col-md-6">
            <div id="react-cost-calculator" data-listing="<%= encodeURIComponent(JSON.stringify(listing)) %>"></div>
          </div>
          <div class="col-md-6">
            <div class="border-0 bg-white h-100" style="border-radius: 24px; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05), 0 8px 10px -6px rgba(0,0,0,0.05);">
              <div class="p-4 border-bottom" style="border-color: #f1f5f9;">
                <h6 class="mb-0 fw-bold d-flex align-items-center text-dark" style="font-size: 1.2rem;">
                  <div class="d-flex align-items-center justify-content-center bg-light rounded-circle me-3 shadow-sm" style="width: 48px; height: 48px; color: #3b82f6;">
                    <i class="fa-solid fa-list-check fs-5"></i>
                  </div>
                  PG Information
                </h6>
              </div>
              <div class="p-4" style="background-color: #fafaf9; border-bottom-left-radius: 24px; border-bottom-right-radius: 24px; min-height: calc(100% - 81px);">
                <ul class="list-unstyled mb-0 w-100">
                  <li class="d-flex justify-content-between align-items-center py-2 mb-2" style="border-bottom: 1px dashed #e2e8f0;">
                    <span class="text-secondary fw-medium fs-6"><i class="fa-solid fa-bed me-2 text-muted"></i>Room Type</span>
                    <span class="fw-bold text-dark fs-6 text-capitalize"><%= listing.roomType || 'single' %></span>
                  </li>
                  <li class="d-flex justify-content-between align-items-center py-2 mb-2" style="border-bottom: 1px dashed #e2e8f0;">
                    <span class="text-secondary fw-medium fs-6"><i class="fa-solid fa-utensils me-2 text-muted"></i>Food Included</span>
                    <span class="fw-bold fs-6 <%= listing.foodIncluded ? 'text-success' : 'text-danger' %>"><%= listing.foodIncluded ? 'Yes' : 'No' %></span>
                  </li>
                  <li class="d-flex justify-content-between align-items-center py-2 mb-2" style="border-bottom: 1px dashed #e2e8f0;">
                    <span class="text-secondary fw-medium fs-6"><i class="fa-solid fa-wifi me-2 text-muted"></i>Wifi</span>
                    <span class="fw-bold fs-6 <%= listing.wifiAvailable ? 'text-success' : 'text-danger' %>"><%= listing.wifiAvailable ? 'Available' : 'Not available' %></span>
                  </li>      
                  <li class="d-flex justify-content-between align-items-center py-2 mb-2" style="border-bottom: 1px dashed #e2e8f0;">
                    <span class="text-secondary fw-medium fs-6"><i class="fa-solid fa-user-group me-2 text-muted"></i>Gender Pref</span>
                    <span class="fw-bold text-dark fs-6 text-capitalize"><%= listing.genderPreference || 'unisex' %></span>
                  </li>
                  <li class="d-flex justify-content-between align-items-center py-2 mt-3 p-3 rounded-4 shadow-sm" style="background: #f8fafc; border: 1px solid #e2e8f0;">
                    <span class="text-secondary fw-bold fs-6">Security Deposit</span>
                    <span class="fw-bold fs-5" style="color: #0f172a;">&#8377; <%= listing.depositAmount?.toLocaleString('en-IN') || 0 %></span>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <% if (currentUser && listing.owner && currentUser._id.equals(listing.owner._id)) { %>
           <span class="badge bg-success mt-4 mb-3">Your Listing - Owned by <%= listing.owner.username %></span>  
        <div class="d-flex gap-2">
          <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary">Edit</a>
          <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE" style="display:inline;">
            <button class="btn btn-danger">Delete</button>
          </form>
        </div>
        <% } %>

      </div>
    </div>
    
    <!-- add review form -->
    <div class="mb-5" id="share-review-form">
      <hr class="my-4">
      <div class="card border-0 shadow-sm p-4" style="background: #fafafa;">
        <h4 class="mb-4 fw-semibold">Share Your Experience</h4>
        <% if (!currentUser) { %>
          <div class="alert alert-info mb-4" role="alert">
            <i class="fa-solid fa-info-circle me-2"></i>
            <strong>Want to share your stay?</strong> <a href="/login" class="alert-link">Login</a> or <a href="/signup" class="alert-link">Sign up</a> to write a review.
          </div>
        <% } else { %>
        <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Food Quality</label>
              <select class="form-select" name="review[foodQuality]" required>
                <option value="">Select</option>
                <% for(let i=1;i<=5;i++){ %>
                  <option value="<%= i %>"><%= i %> ★</option>
                <% } %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Cleanliness</label>
              <select class="form-select" name="review[cleanliness]" required>
                <option value="">Select</option>
                <% for(let i=1;i<=5;i++){ %>
                  <option value="<%= i %>"><%= i %> ★</option>
                <% } %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">WiFi</label>
              <select class="form-select" name="review[wifi]" required>
                <option value="">Select</option>
                <% for(let i=1;i<=5;i++){ %>
                  <option value="<%= i %>"><%= i %> ★</option>
                <% } %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Noise</label>
              <select class="form-select" name="review[noise]" required>
                <option value="">Select</option>
                <% for(let i=1;i<=5;i++){ %>
                  <option value="<%= i %>"><%= i %> ★</option>
                <% } %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Safety</label>
              <select class="form-select" name="review[safety]" required>
                <option value="">Select</option>
                <% for(let i=1;i<=5;i++){ %>
                  <option value="<%= i %>"><%= i %> ★</option>
                <% } %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Owner Behavior</label>
              <select class="form-select" name="review[ownerBehavior]" required>
                <option value="">Select</option>
                <% for(let i=1;i<=5;i++){ %>
                  <option value="<%= i %>"><%= i %> ★</option>
                <% } %>
              </select>
            </div>
          </div>

          <div class="mb-4 mt-3">
            <label for="comments" class="form-label fw-semibold mb-2" style="font-size: 1.05rem;">Tell us about your stay</label>
            <textarea name="review[comment]" id="comments" class="form-control" cols="30" rows="5" required placeholder="Share your experience..." style="font-size: 1rem; border-radius: 8px;"></textarea>
            <div class="invalid-feedback">Please add some comments for the review.</div>
          </div>
          <button class="btn btn-dark rounded-pill px-4 py-2" style="font-weight: 500;">Submit Review</button>
        </form>
        <% } %>
      </div>

      <!-- react interactive reviews mount -->
      <div id="react-interactive-reviews" 
           data-listing-id="<%= listing._id %>"
           data-current-user="<%= currentUser ? currentUser._id : '' %>"
           data-reviews="<%= encodeURIComponent(JSON.stringify(listing.reviews)) %>">
      </div>

      <!-- cta banner -->
      <div class="mb-5 mt-5">
        <hr class="my-4">
        <div class="card border-0 shadow-sm p-5" style="background: linear-gradient(135deg, rgba(52,58,64,0.05) 0%, rgba(52,58,64,0.02) 100%); text-align: center;">
          <h4 class="fw-bold mb-2">Have You Stayed Here?</h4>
          <p class="text-muted fs-5 mb-4">Help other students find the perfect PG by sharing your experience</p>
          <% if (!currentUser) { %>
            <p class="text-muted mb-3">You need to be logged in to share your experience</p>
            <a href="/login" class="btn btn-dark btn-lg rounded-pill px-5">Login to Share Review</a>
          <% } else { %>
            <a href="#share-review-form" class="btn btn-dark btn-lg rounded-pill px-5">Share Your Experience Now</a>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="mb-5">
  <div class="row mt-2 justify-content-center">
    <div class="col-12 col-lg-8 px-2 px-lg-0">
      <hr class="my-4">
      <h3 class="mb-3">Where you'll be staying</h3>
      <div class="card border-0 shadow-sm map-wrapper">
        <div id="map" class="map-box"></div>
      </div>
    </div>
  </div>
</div>

</div>

<script src="/js/map.js"></script>
<script src="/js/react-bundle.js"></script>

