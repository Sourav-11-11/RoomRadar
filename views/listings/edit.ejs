<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
  <div class="col-8 offset-2">
    <h3>Edit your PG Listing</h3>
    <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data">
      
      <div class="mb-3">
        <label for="title" class="form-label">Title:</label>
        <input 
            name="listing[title]" 
            value="<%= listing.title %>" 
            placeholder="Add a Catchy title" 
            type="text" class="form-control" 
            required
        />
        <div class="valid-feedback">Title Looks good!</div>
      </div>
      
      <div class="mb-3">
        <label for="description" class="form-label">Description:</label>
        <textarea 
            name="listing[description]" 
            placeholder="enter description" 
            class="form-control" 
            rows="4" cols="50" 
            required
          >
        <%= listing.description %></textarea>
        <div class="invalid-feedback">Please enter a short description.</div>
      </div>
      
      <div class="mb-3">
        Original Image:
        <img src="<%= originalImageUrl %>" alt="Listing Image" class="img-thumbnail mb-2" style="max-width: 200px;">
      </div>
      <div class="mb-3">
        <label for="image" class="form-label">Upload New Image:</label>
        <input 
            name="listing[image]" 
            
            type="file" 
            class="form-control"/>
      </div>
      
      <div class="row">
        <div class="mb-3 col-md-4">
          <label for="price" class="form-label">Base Rent (per month):</label>
          <input name="listing[price]" value="<%= listing.price %>" placeholder="enter price" type="number" class="form-control" required/>
          <div class="invalid-feedback">Price should be valid</div>
        </div>

        <div class="mb-3 col-md-4">
          <label for="electricityCost" class="form-label">Electricity (per month):</label>
          <input name="listing[electricityCost]" value="<%= listing.electricityCost %>" placeholder="800" type="number" class="form-control" required/>
        </div>

        <div class="mb-3 col-md-4">
          <label for="maintenanceCost" class="form-label">Maintenance (per month):</label>
          <input name="listing[maintenanceCost]" value="<%= listing.maintenanceCost %>" placeholder="500" type="number" class="form-control" required/>
        </div>
      </div>

      <div class="row">
        <div class="mb-3 col-md-4">
          <label for="depositAmount" class="form-label">Deposit Amount:</label>
          <input name="listing[depositAmount]" value="<%= listing.depositAmount %>" placeholder="10000" type="number" class="form-control" required/>
        </div>

        <div class="mb-3 col-md-4">
          <label for="roomType" class="form-label">Room Type:</label>
          <select name="listing[roomType]" class="form-select" required>
            <option value="single" <%= listing.roomType === 'single' ? 'selected' : '' %>>Single</option>
            <option value="double" <%= listing.roomType === 'double' ? 'selected' : '' %>>Double</option>
            <option value="triple" <%= listing.roomType === 'triple' ? 'selected' : '' %>>Triple</option>
          </select>
        </div>

        <div class="mb-3 col-md-4">
          <label for="genderPreference" class="form-label">Gender Preference:</label>
          <select name="listing[genderPreference]" class="form-select" required>
            <option value="boys" <%= listing.genderPreference === 'boys' ? 'selected' : '' %>>Boys</option>
            <option value="girls" <%= listing.genderPreference === 'girls' ? 'selected' : '' %>>Girls</option>
            <option value="unisex" <%= listing.genderPreference === 'unisex' ? 'selected' : '' %>>Unisex</option>
          </select>
        </div>
      </div>

      <div class="row align-items-center">
        <div class="mb-3 col-md-4 form-check">
          <input class="form-check-input" type="checkbox" value="true" id="foodIncluded" name="listing[foodIncluded]" <%= listing.foodIncluded ? 'checked' : '' %>>
          <label class="form-check-label" for="foodIncluded">Food Included</label>
        </div>
        <div class="mb-3 col-md-4 form-check">
          <input class="form-check-input" type="checkbox" value="true" id="wifiAvailable" name="listing[wifiAvailable]" <%= listing.wifiAvailable !== false ? 'checked' : '' %>>
          <label class="form-check-label" for="wifiAvailable">Wifi Available</label>
        </div>
      </div>

      <div class="row">
        <div class="mb-3 col-md-8">
          <label for="country" class="form-label">Country:</label>
          <input
            name="listing[country]"
            placeholder="India"
            value="<%= listing.country %>"
            type="text"
            class="form-control" required   
          />
          <div class="invalid-feedback">Please enter a country.</div>
        </div>
      </div>
            
      <div class="mb-3">
        <label for="location" class="form-label">Location:</label>
        <input
          name="listing[location]"
          placeholder="enter location"
          value="<%= listing.location %>"
          type="text"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Please enter a location.</div>
      </div>
      <button class="btn btn-dark edit-btn mt-3">Edit</button>
      <br><br>
    </form>
  </div>  
</div>
