<% layout("/layouts/boilerplate") %>
<div class="home-wrapper">
    <!-- Hero Section -->
    <section class="hero-section">
        <div class="hero-content">
            <h1 class="hero-title">Find a PG you'll actually <span>survive</span> in.</h1>
            <p class="hero-tagline">Real reviews. Real costs. No surprises.</p>
            
            <div class="search-card">
                <form action="/listings" method="GET" class="home-search-form">
                    <div class="search-input-wrap">
                        <label>City</label>
                        <input type="text" name="location" placeholder="e.g. Hyderabad" class="form-control-custom">
                    </div>
                    <div class="search-divider"></div>
                    <div class="search-input-wrap">
                        <label>Budget</label>
                        <select name="filter" class="form-control-custom">
                            <option value="all">Any</option>
                            <option value="low-budget">Under ₹8K/month</option>
                            <option value="mid-range">₹8K - ₹15K/month</option>
                            <option value="premium-pg">Above ₹15K/month</option>
                        </select>
                    </div>
                    <div class="search-input-wrap">
                        <label>Room Type</label>
                        <select name="roomType" class="form-control-custom">
                            <option value="">Any</option>
                            <option value="single">Single</option>
                            <option value="double">Double Sharing</option>
                        </select>
                    </div>
                    <button type="submit" class="btn-search-primary">
                        <i class="fa-solid fa-magnifying-glass"></i> Search
                    </button>
                </form>

                <div class="quick-filters mt-3">
                    <span class="text-muted small fw-bold me-2">QUICK SEARCH:</span>
                    <a href="/listings?filter=low-budget" class="quick-pill">Low Budget</a>
                    <a href="/listings?filter=food-included" class="quick-pill">Food Included</a>
                    <a href="/listings?filter=wifi-available" class="quick-pill">WiFi</a>
                    <a href="/listings?filter=girls-pg" class="quick-pill">Girls PG</a>
                    <a href="/listings?filter=boys-pg" class="quick-pill">Boys PG</a>
                    <a href="/listings" class="quick-pill" style="background: var(--accent-primary); color: white; font-weight: 600;">→ Explore All</a>
                </div>
            </div>
        </div>
    </section>

    <!-- City Discovery -->
    <section class="city-section">
        <div class="container-fluid px-sm-5">
            <div class="section-header text-center mb-5">
                <h2 class="section-title">Explore Top Hubs</h2>
                <p class="text-muted">Find exactly what you need in the best student cities.</p>
            </div>
            
            <div class="city-grid">
                <!-- City Cards -->
                <a href="/listings?q=Hyderabad" class="city-card">
                    <img src="https://images.unsplash.com/photo-1657981630164-769503f3a9a8?q=80&w=735&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="Hyderabad">
                    <div class="city-info">
                        <h4>Hyderabad</h4>
                        <p>Tech Hubs & Coaching</p>
                    </div>
                </a>
                <div class="city-card position-relative" style="cursor: not-allowed;">
                    <img src="https://images.unsplash.com/photo-1596176530529-78163a4f7af2?w=600&auto=format&fit=crop&q=80" alt="Bangalore" style="filter: brightness(0.5) grayscale(50%);">
                    <div class="city-info" style="opacity: 0.6;">
                        <h4>Bangalore</h4>
                        <p>Startup Capitals</p>
                    </div>
                    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(255, 255, 255, 0.15); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.3); color: #fff; padding: 10px 24px; border-radius: 30px; font-weight: 700; font-size: 14px; letter-spacing: 1px; text-transform: uppercase; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3); z-index: 10; white-space: nowrap;">
                        <i class="fa-solid fa-lock me-2"></i>Coming Soon
                    </div>
                </div>
                <div class="city-card position-relative" style="cursor: not-allowed;">
                    <img src="https://images.unsplash.com/photo-1594233666755-d1cb282abd25?q=80&w=1110&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="Pune" style="filter: brightness(0.5) grayscale(50%);">
                    <div class="city-info" style="opacity: 0.6;">
                        <h4>Pune</h4>
                        <p>Student Friendly</p>
                    </div>
                    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(255, 255, 255, 0.15); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.3); color: #fff; padding: 10px 24px; border-radius: 30px; font-weight: 700; font-size: 14px; letter-spacing: 1px; text-transform: uppercase; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3); z-index: 10; white-space: nowrap;">
                        <i class="fa-solid fa-lock me-2"></i>Coming Soon
                    </div>
                </div>
                <div class="city-card position-relative" style="cursor: not-allowed;">
                    <img src="https://images.unsplash.com/photo-1587474260584-136574528ed5?w=600&auto=format&fit=crop&q=80" alt="Delhi" style="filter: brightness(0.5) grayscale(50%);">
                    <div class="city-info" style="opacity: 0.6;">
                        <h4>Delhi</h4>
                        <p>North & South Campus</p>
                    </div>
                    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(255, 255, 255, 0.15); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.3); color: #fff; padding: 10px 24px; border-radius: 30px; font-weight: 700; font-size: 14px; letter-spacing: 1px; text-transform: uppercase; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3); z-index: 10; white-space: nowrap;">
                        <i class="fa-solid fa-lock me-2"></i>Coming Soon
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Reality Score -->
    <section class="reality-section">
        <div class="container-fluid px-sm-5">
            <div class="row align-items-center">
                <div class="col-lg-5 mb-4 mb-lg-0 text-center text-lg-start">
                    <h2 class="section-title">The Reality Score</h2>
                    <p class="section-desc">We don't trust heavily filtered photos. Our community rates PGs based on real conditions, hidden costs, and actual food quality.</p>
                    <a href="/listings" class="btn-outline-custom mt-3">See Top Rated PGs</a>
                </div>
                <div class="col-lg-7">
                    <div class="score-cards-wrapper staggered-fade-in">
                        <div class="score-card position-relative overflow-hidden">
                            <div class="score-badge d-flex justify-content-center align-items-center" style="background-color: #10b981; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3); min-width: 60px; height: 60px; border-radius: 16px; color: white; font-weight: 700; font-size: 1.5rem; font-family: var(--font-display);">
                                92
                            </div>
                            <div class="score-details flex-grow-1 ms-3">
                                <h5 class="mb-1 d-flex justify-content-between align-items-center" style="font-family: var(--font-display); font-size: 1.1rem; color: var(--text-main);">
                                    Top Rated <span class="badge bg-success-subtle text-success rounded-pill px-2 py-1" style="font-size: 0.75rem; font-weight: 600;"><i class="fa-solid fa-circle-check me-1"></i>Verified</span>
                                </h5>
                                <p class="text-muted small mb-0" style="font-size: 0.9rem;"><i class="fa-solid fa-utensils me-1 opacity-75"></i>Great food <span class="mx-1">•</span> <i class="fa-solid fa-wifi me-1 opacity-75"></i>Fast WiFi</p>
                            </div>
                        </div>
                        <div class="score-card position-relative overflow-hidden mt-3">
                            <div class="score-badge d-flex justify-content-center align-items-center" style="background-color: #f59e0b; box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3); min-width: 60px; height: 60px; border-radius: 16px; color: white; font-weight: 700; font-size: 1.5rem; font-family: var(--font-display);">
                                68
                            </div>
                            <div class="score-details flex-grow-1 ms-3">
                                <h5 class="mb-1 d-flex justify-content-between align-items-center" style="font-family: var(--font-display); font-size: 1.1rem; color: var(--text-main);">
                                    Average <span class="badge bg-warning-subtle text-warning rounded-pill px-2 py-1" style="font-size: 0.75rem; font-weight: 600;"><i class="fa-solid fa-triangle-exclamation me-1"></i>Mixed</span>
                                </h5>
                                <p class="text-muted small mb-0" style="font-size: 0.9rem;"><i class="fa-solid fa-broom me-1 opacity-75"></i>Okay cleaning <span class="mx-1">•</span> <i class="fa-solid fa-volume-high me-1 opacity-75"></i>Noisy</p>
                            </div>
                        </div>
                        <div class="score-card position-relative overflow-hidden mt-3">
                            <div class="score-badge d-flex justify-content-center align-items-center" style="background-color: #ef4444; box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3); min-width: 60px; height: 60px; border-radius: 16px; color: white; font-weight: 700; font-size: 1.5rem; font-family: var(--font-display);">
                                45
                            </div>
                            <div class="score-details flex-grow-1 ms-3">
                                <h5 class="mb-1 d-flex justify-content-between align-items-center" style="font-family: var(--font-display); font-size: 1.1rem; color: var(--text-main);">
                                    Avoid <span class="badge bg-danger-subtle text-danger rounded-pill px-2 py-1" style="font-size: 0.75rem; font-weight: 600;"><i class="fa-solid fa-skull-crossbones me-1"></i>Red Flag</span>
                                </h5>
                                <p class="text-muted small mb-0" style="font-size: 0.9rem;"><i class="fa-solid fa-droplet-slash me-1 opacity-75"></i>Water issues <span class="mx-1">•</span> <i class="fa-solid fa-money-bill-transfer me-1 opacity-75"></i>Hidden fees</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="cta-section text-center">
        <div class="cta-content">
            <h2>Stop guessing. Start comparing.</h2>
            <p>Join thousands of students finding their perfect basecamp.</p>
            <a href="/listings" class="btn-primary-large">Browse All PGs</a>
        </div>
    </section>
</div>